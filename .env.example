# Copy this file to .env for local development. On Render, these are set as
# Environment Variables in the dashboard instead (render.yaml wires up
# DATABASE_URL and SESSION_SECRET automatically).

DATABASE_URL=postgres://user:password@localhost:5432/fsvp_builder
SESSION_SECRET=replace-with-a-long-random-string
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# Free-unlock testing mode (ignored automatically once STRIPE_SECRET_KEY is set)
ALLOW_FREE_UNLOCK=true

# Stripe (see STRIPE_SETUP.md) — leave unset until you're ready to take payments
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID_ONE_TIME=price_...
# STRIPE_PRICE_ID_STORAGE_SUBSCRIPTION=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
